{
  "version": 1,
  "include": ["/*"],
  "exclude": [
    "/api/*",
    "/favicon.ico"
  ],
  "headers": {
    "/_next/static/chunks/*.js": {
      "Cache-Control": "public, max-age=31536000, immutable",
      "Content-Type": "application/javascript"
    },
    "/_next/static/css/*": {
      "Cache-Control": "public, max-age=31536000, immutable",
      "Content-Type": "text/css"
    },
    "/_next/static/*": {
      "Cache-Control": "public, max-age=31536000, immutable",
      "Content-Type": {
        ".js": "application/javascript",
        ".css": "text/css",
        ".woff2": "font/woff2",
        ".jpg": "image/jpeg",
        ".png": "image/png",
        ".gif": "image/gif",
        ".ico": "image/x-icon",
        ".svg": "image/svg+xml"
      }
    }
  }
}
