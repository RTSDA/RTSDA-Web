{
  "version": 1,
  "include": ["/*"],
  "exclude": [
    "/_next/static/*",
    "/static/*",
    "/api/*",
    "/_next/*",
    "/favicon.ico"
  ],
  "headers": {
    "/_next/static/*": {
      "Cache-Control": "public, max-age=31536000, immutable",
      "Content-Type": {
        ".js": "application/javascript",
        ".css": "text/css",
        ".woff2": "font/woff2",
        ".jpg": "image/jpeg",
        ".png": "image/png",
        ".gif": "image/gif",
        ".ico": "image/x-icon",
        ".webp": "image/webp"
      }
    }
  }
}
